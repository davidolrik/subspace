listen "127.0.0.1:8118"

// upstream "corporate" {
//   type "http"
//   address "proxy.corp.com:3128"
//   username "user"
//   password "pass"
// }

// route ".corp.internal" via="corporate"

// "blackhole" is a built-in pseudo-upstream that drops traffic with a
// fast refusal (HTTP 451 / SOCKS5 0x02). No upstream block needed.
// route ".doubleclick.net" via="blackhole"
// route "*.telemetry.com"  via="blackhole"

// Go net/http/pprof debug server, off by default. Exposes runtime
// internals and lets callers trigger expensive profiles — keep it on
// loopback. listen defaults to 127.0.0.1:6060 when omitted.
// pprof {
//   enabled true
//   listen "127.0.0.1:6060"
// }
